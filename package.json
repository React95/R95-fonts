{
  "name": "@react95/sans-serif",
  "main": "index.css",
  "description": "MS Serif and MS Sans Serif from Windows 95, converted to TTF and WOFF2",
  "exports": {
    ".":                       "./index.css",
    "./serif":                 "./serif.css",
    "./serif/8pt":             "./serif-8pt.css",
    "./serif/10pt":            "./serif-10pt.css",
    "./serif/12pt":            "./serif-12pt.css",
    "./serif/14pt":            "./serif-14pt.css",
    "./serif/18pt":            "./serif-18pt.css",
    "./serif/24pt":            "./serif-24pt.css",
    "./serif-hires":           "./serif-hires.css",
    "./serif-hires/8pt":       "./serif-hires-8pt.css",
    "./serif-hires/10pt":      "./serif-hires-10pt.css",
    "./serif-hires/12pt":      "./serif-hires-12pt.css",
    "./serif-hires/14pt":      "./serif-hires-14pt.css",
    "./serif-hires/18pt":      "./serif-hires-18pt.css",
    "./serif-hires/24pt":      "./serif-hires-24pt.css",
    "./sans-serif":            "./sans-serif.css",
    "./sans-serif/8pt":        "./sans-serif-8pt.css",
    "./sans-serif/10pt":       "./sans-serif-10pt.css",
    "./sans-serif/12pt":       "./sans-serif-12pt.css",
    "./sans-serif/14pt":       "./sans-serif-14pt.css",
    "./sans-serif/18pt":       "./sans-serif-18pt.css",
    "./sans-serif/24pt":       "./sans-serif-24pt.css",
    "./sans-serif-hires":      "./sans-serif-hires.css",
    "./sans-serif-hires/8pt":  "./sans-serif-hires-8pt.css",
    "./sans-serif-hires/10pt": "./sans-serif-hires-10pt.css",
    "./sans-serif-hires/12pt": "./sans-serif-hires-12pt.css",
    "./sans-serif-hires/14pt": "./sans-serif-hires-14pt.css",
    "./sans-serif-hires/18pt": "./sans-serif-hires-18pt.css",
    "./sans-serif-hires/24pt": "./sans-serif-hires-24pt.css"
  },
  "version": "0.0.3",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist"
  },
  "devDependencies": {
    "@react95/clippy": "^1.0.13",
    "@react95/core": "^6.1.6",
    "@react95/icons": "^2.0.8",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/styled-components": "^5.1.26",
    "@types/xstyled__styled-components": "^1.19.4",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.4",
    "@xstyled/styled-components": "^3.8.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "gh-pages": "^6.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "5",
    "typescript": "^5.0.2",
    "vite": "^4.4.5"
  },
  "files": [
    "*.css",
    "sources/serif/**/*.ttf",
    "sources/serif/**/*.woff2",
    "sources/sans-serif/**/*.ttf",
    "sources/sans-serif/**/*.woff2"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/React95/R95-Sans-serif"
  },
  "publishConfig": {
    "access": "public"
  }
}
